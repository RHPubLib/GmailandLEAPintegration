# Gmail inbox that receives SSRS report emails
# Auth is handled by the service account via domain-wide delegation — no app password needed
GMAIL_ADDRESS=patron-sync@yourdomain.org

# Your staff email domain — addresses ending in this domain are excluded from patron lists
STAFF_EMAIL_DOMAIN=yourdomain.org

# SSRS subscription subject lines (must match exactly what each report subscription sends)
SSRS_SUBJECT_FULL=Full Patron Export
SSRS_SUBJECT_DIGITAL=Digital Patron Export
SSRS_SUBJECT_LIMITED=Limited Patron Export

# Polaris LEAP deep-link base URL — find this in your LEAP web client URL bar
# Format: everything up to and including the # before the patron ID
# Example: https://catalog.yourlibrary.org/leapwebapp/staff/default#patrons/
LEAP_BASE_URL=https://catalog.yourdomain.org/leapwebapp/staff/default#patrons/

# Google Sheets sync (Gmail add-on patron list)
GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json
GOOGLE_SHEET_ID=
